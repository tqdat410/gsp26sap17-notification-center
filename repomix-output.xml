        </customHeader>

        <content>
            <List
                id="popoverNotificationList"
                noDataText="{i18n>noNotifications}"
                growing="true"
                growingThreshold="10"
                growingScrollToLoad="true">
            </List>
        </content>

    </ResponsivePopover>
</core:FragmentDefinition>
