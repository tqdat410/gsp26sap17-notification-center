<file path="webapp/controller/NotificationDetail.controller.js">
/**
 * NotificationDetail.controller.js
 *
 * Notification detail page with actions
 * - ObjectHeader with priority/category/read status
 * - Message panel with HTML rendering
 * - Source object navigation
 * - Footer: delete, toggle read, toggle archive
 * - Auto-marks as read on first load
 */
sap.ui.define([
    'sap/ui/core/mvc/Controller',
    'sap/ui/model/json/JSONModel',
    'sap/m/MessageToast',
    'sap/m/MessageBox',
    'sap/ui/core/routing/History',
    'sap/base/Log',
    'com/gsp26/sap17/notificationcenter/util/NotificationFormatter',
    'com/gsp26/sap17/notificationcenter/util/NotificationActionHelper',
    'com/gsp26/sap17/notificationcenter/util/BooleanHelper',
    'com/gsp26/sap17/notificationcenter/util/CrossAppNavigation'
], function (Controller, JSONModel, MessageToast, MessageBox, History, Log,
             Formatter, ActionHelper, BooleanHelper, CrossAppNav) {
    'use strict';

    var EVENT_CHANNEL = 'notification.center';
    var EVENT_REFRESH = 'refreshList';

    return Controller.extend('com.gsp26.sap17.notificationcenter.controller.NotificationDetail', {

        // Formatters on prototype so XML template processor finds them at parse time
        formatPriorityText: function (s) {
            var oBundle = this.getView() && this.getView().getModel('i18n') ? this.getView().getModel('i18n').getResourceBundle() : null;
            return Formatter.formatPriorityText(s, oBundle);
        },
        formatPriorityState: Formatter.formatPriorityState,
        formatCategory: function (s) {
            var oBundle = this.getView() && this.getView().getModel('i18n') ? this.getView().getModel('i18n').getResourceBundle() : null;
            return Formatter.formatCategory(s, oBundle);
        },
        formatReadStatusText: function (v) {
            var oBundle = this.getView() && this.getView().getModel('i18n') ? this.getView().getModel('i18n').getResourceBundle() : null;
            return Formatter.formatReadStatusText(v, oBundle);
        },
        formatReadStatusState: Formatter.formatReadStatusState,
        formatArchivedStatusVisible: Formatter.formatArchivedStatusVisible,
        formatFullDateTime: Formatter.formatFullDateTime,
        formatMarkReadText: function (v) {
            var oBundle = this.getView() && this.getView().getModel('i18n') ? this.getView().getModel('i18n').getResourceBundle() : null;
            return Formatter.formatMarkReadText(v, oBundle);
        },
        formatMarkReadIcon: Formatter.formatMarkReadIcon,
        formatArchiveText: function (v) {
            var oBundle = this.getView() && this.getView().getModel('i18n') ? this.getView().getModel('i18n').getResourceBundle() : null;
            return Formatter.formatArchiveText(v, oBundle);
        },
        formatArchiveIcon: Formatter.formatArchiveIcon,
        formatSourceObjectType: function (s) {
            var oBundle = this.getView() && this.getView().getModel('i18n') ? this.getView().getModel('i18n').getResourceBundle() : null;
            return Formatter.formatSourceObjectType(s, oBundle);
        },

        onInit: function () {
            this.getView().setModel(new JSONModel({ busy: false }), 'view');
            this.getOwnerComponent().getRouter().getRoute('detail').attachPatternMatched(this._onRouteMatched, this);
        },

        _onRouteMatched: function (oEvent) {
            var oArgs = oEvent.getParameter('arguments');
            this._sNotificationId = oArgs.notificationId;
            this._sRecipientId = oArgs.recipientId;
            this._bAutoMarkReadDone = false;
            this._bindView(this._sRecipientId, this._sNotificationId);
        },

        _bindView: function (sRecipientId, sNotificationId) {
            var oView = this.getView();
            var oVM = oView.getModel('view');
            var that = this;
            oVM.setProperty('/busy', true);

            var sPath = '/Recipient(RecipientID=' + sRecipientId + ',NotificationID=' + sNotificationId + ')';

            oView.bindElement({
                path: sPath,
                parameters: { $expand: '_Notification($expand=_Actions)' },
                events: {
                    dataRequested: function () { oVM.setProperty('/busy', true); },
                    dataReceived: function () {
                        oVM.setProperty('/busy', false);
                        that._autoMarkAsRead();
                    }
                }
            });
        },

        _autoMarkAsRead: function () {
            if (this._bAutoMarkReadDone) { return; }
            this._bAutoMarkReadDone = true;

            var oCtx = this.getView().getBindingContext();
            var that = this;
            if (!oCtx) { return; }

            oCtx.requestObject().then(function (oData) {
                if (!oData || BooleanHelper.isTrue(oData.IsRead)) { return; }
                var sId = oData.NotificationID;
                if (!sId) { return; }

                ActionHelper.executeAction(oCtx.getModel(), sId, 'MarkAsRead')
                    .then(function () {
                        that.getOwnerComponent().refreshUnreadCount();
                        oCtx.refresh();
                        that._publishRefresh();
                    }).catch(function (oErr) {
                        Log.error('Auto mark-as-read failed: ' + oErr.message);
                    });
            });
        },

        onNavBack: function () {
            var oHistory = History.getInstance();
            if (oHistory.getPreviousHash() !== undefined) {
                window.history.go(-1);
            } else {
                this.getOwnerComponent().getRouter().navTo('main', {}, true);
            }
        },

        onNavigateToSource: function () {
            var oCtx = this.getView().getBindingContext();
            if (!oCtx) { return; }
            var sSrc = oCtx.getProperty('_Notification/SourceType');
            var sKey = oCtx.getProperty('_Notification/ObjectKey');
            if (sSrc && sKey) {
                CrossAppNav.navigateToSource(sSrc, sKey);
            } else {
                MessageToast.show(this._getBundle().getText('noNotifications'));
            }
        },

        onToggleRead: function () {
            var oCtx = this.getView().getBindingContext();
            if (!oCtx) { return; }
            var that = this;
            var bIsRead = oCtx.getProperty('IsRead');
            var sAction = bIsRead ? 'MarkAsUnread' : 'MarkAsRead';

            ActionHelper.executeAction(oCtx.getModel(), oCtx.getProperty('NotificationID'), sAction)
                .then(function () {
                    MessageToast.show(that._getBundle().getText(bIsRead ? 'markUnread' : 'markRead'));
                    that.getOwnerComponent().refreshUnreadCount();
                    oCtx.refresh();
                    that._publishRefresh();
                }).catch(function (oErr) { MessageBox.error(oErr.message); });
        },

        onArchive: function () {
            var oCtx = this.getView().getBindingContext();
            if (!oCtx) { return; }
            var that = this;
            var bArchived = oCtx.getProperty('IsArchived');
            var sAction = bArchived ? 'Unarchive' : 'Archive';

            ActionHelper.executeAction(oCtx.getModel(), oCtx.getProperty('NotificationID'), sAction)
                .then(function () {
                    MessageToast.show(that._getBundle().getText(bArchived ? 'unarchive' : 'archive'));
                    that.getOwnerComponent().refreshUnreadCount();
                    oCtx.refresh();
                    that._publishRefresh();
                }).catch(function (oErr) { MessageBox.error(oErr.message); });
        },

        onDelete: function () {
            var oCtx = this.getView().getBindingContext();
            if (!oCtx) { return; }
            var that = this;

            MessageBox.confirm(this._getBundle().getText('delete') + '?', {
                onClose: function (sBtn) {
                    if (sBtn === MessageBox.Action.OK) {
                        ActionHelper.executeAction(oCtx.getModel(), oCtx.getProperty('NotificationID'), 'MarkAsDeleted')
                            .then(function () {
                                MessageToast.show(that._getBundle().getText('delete'));
                                that.getOwnerComponent().refreshUnreadCount();
                                that._publishRefresh();
                                that.onNavBack();
                            }).catch(function (oErr) { MessageBox.error(oErr.message); });
                    }
                }
            });
        },

        _getBundle: function () { return this.getView().getModel('i18n').getResourceBundle(); },
        _publishRefresh: function () { this.getOwnerComponent().getEventBus().publish(EVENT_CHANNEL, EVENT_REFRESH); }
    });
});
</file>

<file path="webapp/view/NotificationDetail.view.xml">
<mvc:View
    controllerName="com.gsp26.sap17.notificationcenter.controller.NotificationDetail"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:semantic="sap.f.semantic">

    <semantic:SemanticPage
        id="notificationDetailPage"
        headerPinnable="false"
        toggleHeaderOnTitleClick="false"
        showFooter="true"
        showNavButton="true"
        navButtonPress=".onNavBack"
        busy="{view>/busy}"
        busyIndicatorDelay="0">

        <semantic:titleHeading>
            <HBox alignItems="Center">
                <Button
                    icon="sap-icon://nav-back"
                    type="Transparent"
                    press=".onNavBack"
                    class="sapUiTinyMarginEnd"
                    tooltip="{i18n>back}"/>
                <Title text="{i18n>notificationDetails}"/>
            </HBox>
        </semantic:titleHeading>

        <semantic:content>
            <VBox>
                <ObjectHeader
                    id="notificationHeader"
                    class="notificationDetailCard"
                    title="{_Notification/Title}"
                    number=""
                    numberUnit=""
                    condensed="false"
                    backgroundDesign="Transparent"
                    responsive="true">
                    <statuses>
                        <ObjectStatus
                            title="{i18n>priorityLabel}"
                            text="{path: '_Notification/Priority', formatter: '.formatPriorityText'}"
                            state="{path: '_Notification/Priority', formatter: '.formatPriorityState'}"/>
                        <ObjectStatus
                            title="{i18n>categoryLabel}"
                            text="{path: '_Notification/CategoryCode', formatter: '.formatCategory'}"
                            state="Information"/>
                        <ObjectStatus
                            title="{i18n>status}"
                            text="{path: 'IsRead', formatter: '.formatReadStatusText'}"
                            state="{path: 'IsRead', formatter: '.formatReadStatusState'}"/>
                        <ObjectStatus
                            text="{i18n>archived}"
                            state="None"
                            visible="{path: 'IsArchived', formatter: '.formatArchivedStatusVisible'}"/>
                    </statuses>
                    <attributes>
                        <ObjectAttribute
                            title="{i18n>createdAt}"
                            text="{path: '_Notification/CreatedAt', formatter: '.formatFullDateTime'}"/>
                    </attributes>
                </ObjectHeader>

                <Panel
                    headerText="{i18n>message}"
                    expandable="false"
                    class="notificationDetailCard">
                    <content>
                        <FormattedText
                            htmlText="{_Notification/Body}"
                            class="sapUiSmallMargin"/>
                    </content>
                </Panel>

                <Panel
                    id="sourceObjectPanel"
                    headerText="{i18n>sourceObject}"
                    expandable="false"
                    visible="{= !!${_Notification/SourceType} }"
                    class="notificationDetailCard">
                    <content>
                        <HBox alignItems="Center" class="sapUiSmallMargin">
                            <core:Icon
                                src="sap-icon://action"
                                size="1.5rem"
                                color="#0854a0"
                                class="sapUiSmallMarginEnd"/>
                            <VBox>
                                <Text text="{path: '_Notification/SourceType', formatter: '.formatSourceObjectType'}"/>
                                <Link
                                    text="{i18n>openSourceObject}"
                                    press=".onNavigateToSource"/>
                            </VBox>
                        </HBox>
                    </content>
                </Panel>
            </VBox>
        </semantic:content>

        <semantic:footerMainAction>
            <semantic:FooterMainAction
                id="btnNavigateSource"
                text="{i18n>openSourceObject}"
                icon="sap-icon://action"
                visible="{= !!${_Notification/SourceType} }"
                press=".onNavigateToSource"/>
        </semantic:footerMainAction>

        <semantic:footerCustomActions>
            <Button id="btnDelete"
                text="{i18n>delete}" icon="sap-icon://delete"
                type="Reject" press=".onDelete"/>
            <Button id="btnToggleRead"
                text="{path: 'IsRead', formatter: '.formatMarkReadText'}"
                icon="{path: 'IsRead', formatter: '.formatMarkReadIcon'}"
                type="Transparent" press=".onToggleRead"/>
            <Button id="btnArchive"
                text="{path: 'IsArchived', formatter: '.formatArchiveText'}"
                icon="{path: 'IsArchived', formatter: '.formatArchiveIcon'}"
                type="Transparent" press=".onArchive"/>
        </semantic:footerCustomActions>

    </semantic:SemanticPage>
</mvc:View>
</file>

<file path="webapp/view/NotificationList.view.xml">
<mvc:View
    controllerName="com.gsp26.sap17.notificationcenter.controller.NotificationList"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:semantic="sap.f.semantic">

    <semantic:SemanticPage
        id="notificationListPage"
        headerPinnable="false"
        toggleHeaderOnTitleClick="false">

        <semantic:titleHeading>
            <Title text="{i18n>allNotifications}"/>
        </semantic:titleHeading>

        <semantic:content>
            <IconTabBar
                id="notificationTabs"
                class="notificationTabBar"
                select=".onTabSelect"
                selectedKey="{view>/selectedTab}"
                expandable="false"
                stretchContentHeight="true"
                applyContentPadding="false">

                <items>
                    <IconTabFilter key="all" text="{i18n>all}" icon="sap-icon://list"/>
                    <IconTabFilter key="unread" text="{i18n>unread}"
                        icon="sap-icon://email" count="{app>/UnreadCount}"/>
                    <IconTabFilter key="archived" text="{i18n>archived}"
                        icon="sap-icon://folder"/>
                </items>

                <content>
                    <OverflowToolbar design="Solid"
                        class="sapUiTinyMarginBottom notificationFilterBar">
                        <ToolbarSpacer/>
                        <SearchField id="searchField" width="auto"
                            placeholder="{i18n>searchNotifications}"
                            liveChange=".onSearch">
                            <layoutData>
                                <OverflowToolbarLayoutData minWidth="200px"
                                    maxWidth="300px" shrinkable="true" priority="High"/>
                            </layoutData>
                        </SearchField>
                        <ToolbarSeparator/>
                        <Select id="categoryFilter" change=".onCategoryFilterChange"
                            selectedKey="all" width="auto" autoAdjustWidth="true">
                            <items>
                                <core:Item key="all" text="{i18n>allCategories}"/>
                                <core:Item key="TASK" text="{i18n>categoryTask}"/>
                                <core:Item key="SYTM" text="{i18n>categorySystem}"/>
                                <core:Item key="INFO" text="{i18n>categoryInfo}"/>
                                <core:Item key="ALRT" text="{i18n>categoryAlert}"/>
                            </items>
                            <layoutData>
                                <OverflowToolbarLayoutData priority="Low" group="1"/>
                            </layoutData>
                        </Select>
                        <Select id="priorityFilter" change=".onPriorityFilterChange"
                            selectedKey="all" width="auto" autoAdjustWidth="true">
                            <items>
                                <core:Item key="all" text="{i18n>allPriorities}"/>
                                <core:Item key="H" text="{i18n>priorityHigh}"/>
                                <core:Item key="M" text="{i18n>priorityMedium}"/>
                                <core:Item key="L" text="{i18n>priorityLow}"/>
                            </items>
                            <layoutData>
                                <OverflowToolbarLayoutData priority="Low" group="1"/>
                            </layoutData>
                        </Select>
                        <DatePicker id="dateFromFilter" placeholder="{i18n>dateFrom}"
                            change=".onDateFilterChange" width="auto" displayFormat="short">
                            <layoutData>
                                <OverflowToolbarLayoutData priority="Low" group="2"
                                    minWidth="120px" shrinkable="true"/>
                            </layoutData>
                        </DatePicker>
                        <DatePicker id="dateToFilter" placeholder="{i18n>dateTo}"
                            change=".onDateFilterChange" width="auto" displayFormat="short">
                            <layoutData>
                                <OverflowToolbarLayoutData priority="Low" group="2"
                                    minWidth="120px" shrinkable="true"/>
                            </layoutData>
                        </DatePicker>
                    </OverflowToolbar>

                    <Table id="notificationTable" class="notificationTable" width="auto"
                        items="{
                            path: '/Recipient',
                            parameters: {
                                $expand: '_Notification($expand=_Actions)',
                                $count: true
                            },
                            sorter: {
                                path: '_Notification/CreatedAt',
                                descending: true
                            }
                        }"
                        mode="MultiSelect"
                        noDataText="{i18n>noNotifications}"
                        growing="true" growingThreshold="20"
                        growingScrollToLoad="true"
                        itemPress=".onNotificationPress"
                        selectionChange=".onSelectionChange"
                        updateFinished=".onUpdateFinished">
                        <headerToolbar>
                            <OverflowToolbar design="Transparent">
                                <content>
                                    <Title id="tableTitle" text="{i18n>notifications}" level="H2"/>
                                    <ToolbarSpacer/>
                                    <Button id="btnDelete"
                                        text="{view>/deleteButtonText}"
                                        icon="sap-icon://delete" type="Reject"
                                        press=".onDeleteAction"/>
                                    <Button id="btnMarkRead"
                                        text="{view>/markReadButtonText}"
                                        icon="{view>/markReadButtonIcon}"
                                        type="Transparent" press=".onMarkReadAction"/>
                                    <Button id="btnArchive"
                                        text="{view>/archiveButtonText}"
                                        icon="{view>/archiveButtonIcon}"
                                        type="Transparent" press=".onArchiveAction"
                                        visible="{= ${view>/hasSelection} }"/>
                                </content>
                            </OverflowToolbar>
                        </headerToolbar>
                        <columns>
                            <Column>
                                <Text text="{i18n>subjectColumn}"/>
                            </Column>
                            <Column width="8rem" minScreenWidth="Tablet" demandPopin="true">
                                <Text text="{i18n>categoryColumn}"/>
                            </Column>
                            <Column width="6rem" minScreenWidth="Tablet" demandPopin="true">
                                <Text text="{i18n>priorityColumn}"/>
                            </Column>
                            <Column width="10rem" minScreenWidth="Desktop" demandPopin="true">
                                <Text text="{i18n>dateColumn}"/>
                            </Column>
                        </columns>
                        <items>
                            <ColumnListItem vAlign="Middle" type="Navigation"
                                press=".onNotificationPress"
                                highlight="{= ${IsRead} ? 'None' : 'Information'}">
                                <customData>
                                    <core:CustomData key="IsRead" value="{IsRead}" writeToDom="false"/>
                                    <core:CustomData key="IsArchived" value="{IsArchived}" writeToDom="false"/>
                                </customData>
                                <cells>
                                    <FormattedText htmlText="{parts: [
                                        {path: 'IsRead', targetType: 'any'},
                                        {path: '_Notification/Title', targetType: 'any'},
                                        {path: '_Notification/Body', targetType: 'any'}],
                                        formatter: '.formatSubjectHtml'}"/>
                                    <FormattedText htmlText="{parts: [
                                        {path: 'IsRead', targetType: 'any'},
                                        {path: '_Notification/CategoryCode', targetType: 'any'}],
                                        formatter: '.formatCategoryHtml'}"/>
                                    <FormattedText htmlText="{parts: [
                                        {path: 'IsRead', targetType: 'any'},
                                        {path: '_Notification/Priority', targetType: 'any'}],
                                        formatter: '.formatPriorityHtml'}"/>
                                    <FormattedText htmlText="{parts: [
                                        {path: 'IsRead', targetType: 'any'},
                                        {path: '_Notification/CreatedAt', targetType: 'any'}],
                                        formatter: '.formatDateHtml'}"/>
                                </cells>
                            </ColumnListItem>
                        </items>
                    </Table>
                </content>
            </IconTabBar>
        </semantic:content>

        <semantic:positiveAction>
            <semantic:PositiveAction text="{i18n>markAllRead}" press=".onMarkAllAsRead"/>
        </semantic:positiveAction>

        <semantic:negativeAction>
            <semantic:NegativeAction text="{i18n>archiveAll}" press=".onArchiveAll"/>
        </semantic:negativeAction>

    </semantic:SemanticPage>
</mvc:View>
