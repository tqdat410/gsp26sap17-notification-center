<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <CustomListItem id="idSettingsCategoryCustomListItem" class="settingsCategoryItem">
        <VBox id="idSettingsCategoryVBox" class="sapUiSmallMarginBeginEnd sapUiTinyMarginTopBottom">

            <!-- Category name + Required badge -->
            <HBox id="idSettingsHeaderHBox" alignItems="Center" class="sapUiTinyMarginBottom">
                <Title
                    id="idCategoryNameTitle"
                    text="{settingsModel>categoryName}"
                    level="H5"
                    class="sapUiTinyMarginEnd"/>
                <ObjectStatus
                    id="idRequiredBadgeObjectStatus"
                    text="{i18n>required}"
                    icon="sap-icon://locked"
                    state="Information"
                    visible="{settingsModel>obligatory}"/>
            </HBox>

            <!-- Category description -->
            <Text
                id="idCategoryDescText"
                text="{settingsModel>categoryDesc}"
                class="sapUiTinyMarginBottom settingsCategoryDesc"/>

            <!-- In-App switch -->
            <HBox id="idInAppRowHBox" alignItems="Center" class="sapUiTinyMarginTop">
                <Label id="idInAppLabel" text="{i18n>inAppLabel}" width="5rem"/>
                <Switch
                    id="idInAppSwitch"
                    state="{settingsModel>isEnabled}"
                    enabled="{= !${settingsModel>obligatory} &amp;&amp; ${settingsModel>/masterEnabled} }"
                    change=".onSwitchInAppChange"/>
            </HBox>

            <!-- Email switch -->
            <HBox id="idEmailRowHBox" alignItems="Center" class="sapUiTinyMarginTop">
                <Label id="idEmailLabel" text="{i18n>emailLabel}" width="5rem"/>
                <Switch
                    id="idEmailSwitch"
                    state="{settingsModel>emailEnabled}"
                    enabled="{settingsModel>/masterEnabled}"
                    change=".onSwitchEmailChange"/>
            </HBox>

        </VBox>
    </CustomListItem>

</core:FragmentDefinition>
