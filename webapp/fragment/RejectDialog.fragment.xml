<Dialog xmlns="sap.m"
    xmlns:core="sap.ui.core"
    id="idRejectDialog"
    class="rejectReasonDialog"
    title="{i18n>rejectDialogTitle}"
    contentWidth="30rem"
    beforeOpen=".onRejectDialogBeforeOpen"
    afterClose=".onRejectDialogAfterClose">

    <VBox class="rejectDialogContent">
        <Label 
            text="{i18n>rejectReasonLabel}" 
            required="true" 
            class="rejectReasonLabel" />
        
        <TextArea 
            id="idRejectReasonTextArea"
            width="100%" 
            rows="4" 
            placeholder="{i18n>rejectReasonPlaceholder}"
            class="rejectReasonTextArea" />
    </VBox>

    <buttons>
        <Button 
            text="{i18n>submit}" 
            type="Emphasized" 
            press=".onRejectDialogSubmit" />
        <Button 
            text="{i18n>cancel}" 
            press=".onRejectDialogCancel" />
    </buttons>
</Dialog>
