<mvc:View
    controllerName="com.gsp26.sap17.notificationcenter.controller.App"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:f="sap.f"
    displayBlock="true">

    <VBox fitContainer="true">
        <f:ShellBar
            id="shellBar"
            title="{i18n>appTitle}"
            homeIcon="sap-icon://home"
            showMenuButton="true"
            menuButtonPressed=".onMenuPress"
            showNavButton="false"
            showNotifications="true"
            notificationsNumber="{= ${app>/UnreadCount} > 99 ? '99+' : ${app>/UnreadCount} }"
            notificationsPressed=".onNotificationPress"
            homeIconPressed=".onHomePress">
            <f:additionalContent>
                <OverflowToolbarButton
                    id="settingsButton"
                    icon="sap-icon://action-settings"
                    type="Transparent"
                    press=".onSettingsPress"
                    tooltip="{i18n>settings}"/>
            </f:additionalContent>
        </f:ShellBar>

        <App id="app" class="sapUiSizeCompact">
            <layoutData>
                <FlexItemData growFactor="1" baseSize="0%"/>
            </layoutData>
        </App>
    </VBox>
</mvc:View>
